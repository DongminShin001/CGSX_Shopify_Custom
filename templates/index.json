    "services_cgsx": {
      "type": "custom-liquid",
      "name": "Services",
      "settings": {
        "custom_liquid": "<div style=\"padding:96px 5vw;max-width:1200px;margin:0 auto\"><div style=\"text-align:center;margin-bottom:64px\"><span class=\"gallery-eyebrow\">The CGSX Experience</span><h2 style=\"font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3rem);font-weight:300;color:#f0ede8;letter-spacing:-.02em;margin:0\">Beyond the Transaction</h2></div><div style=\"display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:48px\"><div><div style=\"font-family:'Cormorant Garamond',serif;font-size:2rem;color:rgba(201,185,154,.25);font-weight:300;margin-bottom:16px\">I</div><div style=\"width:24px;height:1px;background:#c9b99a;margin-bottom:16px\"></div><div style=\"font-size:1rem;color:#f0ede8;margin-bottom:10px;font-family:'Cormorant Garamond',serif\">Private Advisory</div><div style=\"font-size:.9rem;color:#4a4845;line-height:1.9;font-family:'DM Sans',sans-serif\">Our curators work one-on-one with collectors to identify works that align with their vision and portfolio.</div></div><div><div style=\"font-family:'Cormorant Garamond',serif;font-size:2rem;color:rgba(201,185,154,.25);font-weight:300;margin-bottom:16px\">II</div><div style=\"width:24px;height:1px;background:#c9b99a;margin-bottom:16px\"></div><div style=\"font-size:1rem;color:#f0ede8;margin-bottom:10px;font-family:'Cormorant Garamond',serif\">White-Glove Delivery</div><div style=\"font-size:.9rem;color:#4a4845;line-height:1.9;font-family:'DM Sans',sans-serif\">Every piece is professionally packed, insured, and installed by our specialist team worldwide.</div></div><div><div style=\"font-family:'Cormorant Garamond',serif;font-size:2rem;color:rgba(201,185,154,.25);font-weight:300;margin-bottom:16px\">III</div><div style=\"width:24px;height:1px;background:#c9b99a;margin-bottom:16px\"></div><div style=\"font-size:1rem;color:#f0ede8;margin-bottom:10px;font-family:'Cormorant Garamond',serif\">Provenance & Authentication</div><div style=\"font-size:.9rem;color:#4a4845;line-height:1.9;font-family:'DM Sans',sans-serif\">Each work arrives with a full certificate of authenticity and complete provenance documentation.</div></div></div></div>"
